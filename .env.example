# Server runtime
NODE_ENV=development
PORT=4000

# Stripe — backend reads the first non-empty of these three as the secret key.
# Set STRIPE_KEY in production; the others remain as fallbacks.
STRIPE_KEY=
HIREIT_STRIPE_KEY=
STRIPE_SECRET_KEY=

# Stripe webhook signing secret — verifies incoming webhook events
STRIPE_WEBHOOK_SECRET=

# Resend (transactional email)
RESEND_API_KEY=

# Frontend origin (used in places that reference process.env.FRONTEND_URL —
# CORS itself uses a hardcoded allowlist)
FRONTEND_URL=http://localhost:3000

# Supabase service-role — used by the Stripe webhook handler to write to
# bookings without going through RLS. Treat as a secret; never expose to
# the frontend. Get from: Supabase → Project Settings → API → service_role
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
