# Server runtime
NODE_ENV=development
PORT=4000

# Stripe mode — strict equality with 'test' enables sandbox mode.
# Default (unset, empty, or anything other than 'test') is LIVE.
# Set to 'test' ONLY when you want to point at Stripe's test environment.
STRIPE_MODE=

# Live-mode Stripe keys (used when STRIPE_MODE != 'test')
# Prefer STRIPE_KEY_LIVE for clarity, but legacy STRIPE_KEY / HIREIT_STRIPE_KEY / STRIPE_SECRET_KEY
# are still respected as fallbacks for backwards compatibility.
STRIPE_KEY_LIVE=
STRIPE_WEBHOOK_SECRET_LIVE=

# Test-mode Stripe keys (only used when STRIPE_MODE='test'; required in that case)
STRIPE_KEY_TEST=
STRIPE_WEBHOOK_SECRET_TEST=

# Legacy single-var Stripe — still respected in live mode if the _LIVE vars aren't set.
STRIPE_KEY=
HIREIT_STRIPE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (transactional email)
RESEND_API_KEY=

# Frontend origin (used in places that reference process.env.FRONTEND_URL —
# CORS itself uses a hardcoded allowlist)
FRONTEND_URL=http://localhost:3000

# Supabase service-role — used by the Stripe webhook handler to write to
# bookings without going through RLS. Treat as a secret; never expose to
# the frontend. Get from: Supabase → Project Settings → API → service_role
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
